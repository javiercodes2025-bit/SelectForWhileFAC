------------------ SistemaDePelículas ------------------
CREATE DATABASE sistemadepeliculas;
USE sistemadepeliculas;

-- PERSONA
CREATE TABLE persona (
    id_persona INT PRIMARY KEY AUTO_INCREMENT,
    nombre VARCHAR(100) NOT NULL,
    apellido VARCHAR(100) NOT NULL,

    password VARCHAR(255) NOT NULL,
    habilitado INT DEFAULT 1,
    rol VARCHAR(45) NOT NULL,

    fk_perXtel INT,
    fk_perXemail INT,

    fk_perXdire INT
);



-- EMAIL
CREATE TABLE email(
    id_email INT PRIMARY KEY AUTO_INCREMENT,
    correo VARCHAR(100) NOT NULL,
    habilitado INT DEFAULT 1
);

CREATE TABLE personaXemail(
    id_perXemail INT PRIMARY KEY AUTO_INCREMENT,
    fk_persona INT,
    fk_email INT,

    FOREIGN KEY (fk_persona)
        REFERENCES persona(id_persona),

    FOREIGN KEY (fk_email)
        REFERENCES email(id_email)
);

-- TELEFONOS
CREATE TABLE telefonos(
    id_telefono INT PRIMARY KEY AUTO_INCREMENT,
    numero VARCHAR(30) NOT NULL,
    habilitado INT DEFAULT 1
);

CREATE TABLE personaXtelefonos(
    id_perXtel INT PRIMARY KEY AUTO_INCREMENT,
    fk_persona INT,
    fk_telefono INT,

    FOREIGN KEY (fk_persona)
        REFERENCES persona(id_persona),

    FOREIGN KEY (fk_telefono)
        REFERENCES telefonos(id_telefono)
);

-- DIRECCION
CREATE TABLE direccion(
    id_direccion INT PRIMARY KEY AUTO_INCREMENT,
    calle VARCHAR(100),
    numero VARCHAR(20),
    ciudad VARCHAR(100),

    habilitado INT DEFAULT 1
);

CREATE TABLE personaXdireccion(
    id_perXdire INT PRIMARY KEY AUTO_INCREMENT,
    fk_persona INT,
    fk_direccion INT,

    FOREIGN KEY (fk_persona)
        REFERENCES persona(id_persona),

    FOREIGN KEY (fk_direccion)
        REFERENCES direccion(id_direccion)
);


CREATE TABLE empleado (
    id_empleado INT PRIMARY KEY AUTO_INCREMENT,
    fk_persona INT UNIQUE NOT NULL,

    hora_entrada VARCHAR(10),
    hora_salida VARCHAR(10),
    sueldo INT,

    FOREIGN KEY (fk_persona)
        REFERENCES persona(id_persona)
);

-- DOCUMENTO
CREATE TABLE documento(
    id_documento INT PRIMARY KEY AUTO_INCREMENT,
    numero_documento VARCHAR(20) UNIQUE NOT NULL,
    tipo VARCHAR(25) NOT NULL,
    habilitado INT DEFAULT 1
);

CREATE TABLE empleadosXdocumento(
    id_emplXdocu INT PRIMARY KEY AUTO_INCREMENT,
    fk_empleado INT,
    fk_documento INT,

    FOREIGN KEY (fk_empleado)
        REFERENCES empleado(id_empleado),

    FOREIGN KEY (fk_documento)
        REFERENCES documento(id_documento)
);

CREATE TABLE cliente (
    id_cliente INT PRIMARY KEY AUTO_INCREMENT,
    fk_persona INT UNIQUE NOT NULL,
     dni INT UNIQUE ,

    FOREIGN KEY (fk_persona)
        REFERENCES persona(id_persona)
);

